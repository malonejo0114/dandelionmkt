<%- include('../partials/public-header') %>

<main class="page">
  <section class="section list-shell">
    <div class="list-intro">
      <p class="list-kicker"><%= type === 'portfolio' ? 'Selected Portfolio' : type === 'service' ? 'Operating Services' : 'Journal Archive' %></p>
      <h1 class="section-title"><%= listTitle %></h1>
      <p class="section-subtitle"><%= type === 'portfolio' ? '성과 중심 포트폴리오 사례를 확인하세요.' : type === 'service' ? '운영 서비스 구성과 제공 범위를 확인하세요.' : '운영, 전환, 광고 구조에 대한 인사이트를 발행합니다.' %></p>
      <p class="list-note">
        <%= type === 'portfolio'
          ? '실제 운영 결과와 구조를 중심으로 정리된 사례입니다.'
          : type === 'service'
            ? '집행이 아니라 운영 구조를 설계하기 위한 서비스 구성을 확인할 수 있습니다.'
            : '글 단위로 계속 발행할 수 있는 블로그 아카이브입니다. summary는 목록 설명과 메타 설명에 함께 사용됩니다.' %>
      </p>
      <div class="list-stats">
        <span><%= items.length %> items</span>
        <span><%= type === 'portfolio' ? 'case archive' : type === 'service' ? 'service archive' : 'blog archive' %></span>
      </div>
    </div>

    <div class="square-grid">
      <% if (!items.length) { %>
        <div class="empty">아직 공개된 콘텐츠가 없습니다.</div>
      <% } %>

      <% items.forEach((item) => { %>
        <% const publishedLabel = item.published_at || item.created_at; %>
        <% const summaryText = item.summary || (item.body ? item.body.slice(0, 140) : '상세 페이지에서 전체 내용을 확인하세요.'); %>
        <a class="square-link" href="/<%= type %>/<%= item.slug %>">
          <div class="square-media">
            <% const thumbSrc = item.thumbnail_path || 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1200&q=80'; %>
            <% const isVideo = /\.(mp4|webm|ogg)$/i.test(thumbSrc || ''); %>
            <% if (isVideo) { %>
              <video muted loop autoplay playsinline preload="metadata">
                <source src="<%= thumbSrc %>" />
              </video>
            <% } else { %>
              <img src="<%= thumbSrc %>" alt="<%= item.title %>" />
            <% } %>
          </div>
          <div class="square-overlay">
            <% if (type === 'blog') { %>
              <p class="square-meta">Published · <%= publishedLabel %></p>
            <% } %>
            <p class="square-title"><%= item.title %></p>
            <p class="square-summary"><%= summaryText %></p>
          </div>
        </a>
      <% }) %>
    </div>
  </section>
</main>

<%- include('../partials/public-footer') %>
