<%- include('../partials/public-header') %>

<main class="page">
  <section class="form-shell">
    <div class="contact-layout">
      <aside class="contact-copy">
        <p class="list-kicker">Strategy Contact</p>
        <h1 class="section-title">Contact</h1>
        <p class="section-subtitle">이름, 전화번호, 업체명, 문의사항을 남겨주시면 운영 관점으로 빠르게 답변드립니다.</p>
        <p class="list-note">
          단순 집행 문의가 아니라 현재 구조와 병목을 함께 보고 싶다면 지금 남기면 됩니다.
        </p>
        <div class="contact-points">
          <span>예약 구조 진단</span>
          <span>문의 흐름 진단</span>
          <span>운영 KPI 정리</span>
        </div>
        <div class="contact-policy-card">
          <strong>Retention</strong>
          <p>수집 정보는 상담 목적으로만 이용되며 접수일 기준 <%= inquiryRetentionDays %>일 보관 후 파기됩니다.</p>
        </div>
      </aside>

      <div class="contact-form-panel">
        <% if (formError) { %>
          <div class="error-msg" style="margin-top: 0;"><%= formError %></div>
        <% } %>

        <form class="form-grid" method="post" action="/contact">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="redirectTo" value="/contact" />

          <div class="form-row">
            <label for="name">이름</label>
            <input id="name" name="name" required maxlength="60" />
          </div>

          <div class="form-row">
            <label for="phone">전화번호</label>
            <input id="phone" name="phone" required maxlength="40" />
          </div>

          <div class="form-row">
            <label for="company">업체명</label>
            <input id="company" name="company" required maxlength="120" />
          </div>

          <div class="form-row">
            <label for="message">문의사항</label>
            <textarea id="message" name="message" required maxlength="4000"></textarea>
          </div>

          <div class="form-row">
            <label for="privacyPolicy">개인정보 수집 및 이용 안내</label>
            <textarea id="privacyPolicy" readonly style="min-height: 150px; color: var(--text-soft);"><%= privacyPolicyText %></textarea>
          </div>

          <label class="consent-row">
            <input type="checkbox" name="consent" value="true" required />
            <span>개인정보 수집 및 이용에 동의합니다. (필수)</span>
          </label>

          <div class="inline-actions">
            <button class="btn" type="submit">문의 접수</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/public-footer') %>
