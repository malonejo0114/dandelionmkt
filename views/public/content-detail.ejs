<%- include('../partials/public-header') %>

<main class="page">
  <% const publishedLabel = item.published_at || item.created_at; %>
  <% const detailBodyParagraphs = String(item.body || '').split(/\n{2,}/).map((row) => row.trim()).filter(Boolean); %>
  <% const readingMinutes = Math.max(1, Math.ceil(String(item.body || '').replace(/\s+/g, '').length / 700)); %>
  <article class="detail-wrap">
    <header class="detail-hero">
      <p class="detail-kicker"><%= type === 'portfolio' ? 'Case Detail' : type === 'service' ? 'Service Detail' : 'Blog Article' %></p>
      <h1 class="detail-title"><%= item.title %></h1>
      <p class="detail-meta">
        <%= type %> · <%= publishedLabel %><% if (type === 'blog' && detailBodyParagraphs.length) { %> · <%= readingMinutes %> min read<% } %>
      </p>
      <% if (item.summary) { %>
        <p class="detail-summary"><%= item.summary %></p>
      <% } %>
    </header>

    <% if (item.thumbnail_path) { %>
      <div class="detail-thumb">
        <% const thumbIsVideo = /\.(mp4|webm|ogg)$/i.test(item.thumbnail_path || ''); %>
        <% if (thumbIsVideo) { %>
          <video controls playsinline preload="metadata" src="<%= item.thumbnail_path %>"></video>
        <% } else { %>
          <img src="<%= item.thumbnail_path %>" alt="<%= item.title %>" />
        <% } %>
      </div>
    <% } %>

    <% const hasBlocks = item.blocks && item.blocks.length > 0; %>
    <% if (detailBodyParagraphs.length) { %>
      <section class="detail-body detail-panel <%= type === 'blog' ? 'blog-prose' : '' %>">
        <% detailBodyParagraphs.forEach((paragraph) => { %>
          <p><%= paragraph %></p>
        <% }) %>
      </section>
    <% } %>

    <% if (hasBlocks) { %>
      <section class="content-blocks detail-panel">
        <% item.blocks.forEach((block) => { %>
          <% if (block.block_type === 'text') { %>
            <p class="content-block text"><%= block.content_text %></p>
          <% } else { %>
            <% const source = block.storage_path || block.media_url; %>
            <% const mime = block.mime_type || ''; %>
            <% const isVideo = mime.startsWith('video/') || /\.(mp4|webm|ogg)$/i.test(source || ''); %>
            <% if (source) { %>
              <figure class="content-block media">
                <% if (isVideo) { %>
                  <video controls playsinline preload="metadata" src="<%= source %>"></video>
                <% } else { %>
                  <img src="<%= source %>" alt="<%= block.original_name || item.title %>" />
                <% } %>
                <% if (block.content_text) { %>
                  <figcaption><%= block.content_text %></figcaption>
                <% } %>
              </figure>
            <% } %>
          <% } %>
        <% }) %>
      </section>
    <% } else if (!detailBodyParagraphs.length) { %>
      <div class="detail-body detail-panel"><%= item.body || '등록된 상세 설명이 없습니다.' %></div>
    <% } %>

    <% const usedAssetIds = new Set((item.blocks || []).map((row) => Number(row.media_asset_id)).filter((id) => id > 0)); %>
    <% const extraAssets = (item.mediaAssets || []).filter((media) => !usedAssetIds.has(Number(media.id))); %>
    <% if (extraAssets.length) { %>
      <div class="media-gallery">
        <% extraAssets.forEach((media) => { %>
          <div class="media-item">
            <% if (media.mime_type.startsWith('video/')) { %>
              <video controls preload="metadata" src="<%= media.storage_path %>"></video>
            <% } else { %>
              <img src="<%= media.storage_path %>" alt="<%= media.original_name %>" />
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </article>
</main>

<%- include('../partials/public-footer') %>
